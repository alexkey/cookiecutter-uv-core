#!/usr/bin/env bash

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "ERROR: This script must be sourced." \
         "Use: source ${BASH_SOURCE[0]} [</path/to/venv>]" \
    >&2
    exit 1
fi

#---
# Helper script to activate Python virtual environments
#---
# Searches for virtualenv in the following order:
# * User-specified path (if </path/to/venv> were given).
# * Docker environment path ({{ cookiecutter.docker_prefix }}).
# * Local project path (.venv).


__activate_venv() {
    local user_prefix="${1:-}"
    local primary_prefix="${user_prefix:-{{ cookiecutter.docker_prefix }}/.venv}"
    local secondary_prefix="${PWD}/.venv"
    local prefix=""

    # A user-specified path is authoritative: if it does not exist,
    # do not fall back to the other candidates.
    if [[ -n "${user_prefix}" && ! -d "${user_prefix}" ]]; then
        echo "ERROR: Virtual environment not found at user-specified path:" \
             "\`${user_prefix}\`" \
        >&2
        return 2
    fi

    # Find the first valid path.
    if [[ -d "${primary_prefix}" ]]; then
        prefix="${primary_prefix}"

    elif [[ -d "${secondary_prefix}" ]]; then
        prefix="${secondary_prefix}"

    else
        echo "ERROR: No valid virtual environment found:" \
             "\`${primary_prefix}\`, \`${secondary_prefix}\`" \
        >&2
        return 2
    fi


    local activate_script="${prefix}/bin/activate"

    if [[ ! -f "${activate_script}" ]]; then
        echo "ERROR: Virtual environment activation script not found:" \
             "\`${activate_script}\`" \
        >&2
        return 3
    fi

    echo "Activating virtual environment: \`${prefix}\`..."
    # shellcheck disable=SC1090
    source "${activate_script}"
}


__activate_venv "$@"
__activate_venv_rc=$?

unset -f __activate_venv
return ${__activate_venv_rc}
